<div class="container mt-4">
  <h2>Edit Your Rating for <%= @store.name %></h2>

  <%= form_with(model: [@store, @rating], local: true) do |form| %>
    <div class="form-group">
      <%= form.label :value, "Rating (1-5)" %>
      <%= form.select :value, (1..5).map { |n| [n, n] }, {}, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :comment %>
      <%= form.text_area :comment, class: "form-control" %>
    </div>

    <%= form.submit "Update Rating", class: "btn btn-success" %>
    <%= link_to 'Back to Store', @store, class: "btn btn-secondary" %>
  <% end %>
</div>
