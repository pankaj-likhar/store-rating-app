<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Stores</h1>
    <% if current_user&.system_admin? %>
      <%= link_to 'Add New Store', new_store_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <div class="row">
    <% @stores.each do |store| %>
      <div class="col-md-4 mb-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><%= store.name %></h5>
            <p class="card-text">
              <strong>Average Rating:</strong> <%= store.average_rating.to_f.round(1) %>/5
              <br>
              <span class="text-muted">(<%= store.ratings.count %> reviews)</span>
            </p>
            <p class="card-text"><%= store.address %></p>
            <%= link_to 'View Details', store, class: "btn btn-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
